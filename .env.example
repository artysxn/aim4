# ---------------------------------------------------------------------------
# AIM4.io — environment variables
# Copy to `.env` for local overrides (Vite auto-loads .env; never commit it).
# Variables are split by where they run: CLIENT (build-time, Vite) vs SERVER
# (runtime, Node). CLIENT vars MUST be prefixed VITE_ to be exposed to the app.
# ---------------------------------------------------------------------------

# === CLIENT (build-time, baked into the bundle by Vite) =====================

# Backend origin for the config-share REST API *and* multiplayer (WS + status).
# Leave EMPTY for local dev and LAN/host mode (the client talks to the same
# origin that served it, and Vite proxies /api + /ws to the backend).
# Set it for a SPLIT deploy where the client and backend are on different
# origins (e.g. Vercel client -> Fly.io backend). Include the scheme, no
# trailing slash. The client derives the WebSocket URL from this automatically
# (https -> wss).
#   Production example:
# VITE_API_URL=https://aim4-backend.fly.dev
VITE_API_URL=

# Supabase — auth, cloud settings sync, account leaderboards.
# Get these from Supabase → Project Settings → API (publishable/anon key).
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-publishable-key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# === SERVER (runtime, Node — server/index.js) ==============================

# Interface to bind. 127.0.0.1 (default) for local-only; 0.0.0.0 to accept
# connections from the network — REQUIRED on Fly.io and for LAN/host mode.
AIM4_HOST=127.0.0.1

# Port for the HTTP API + WebSocket. Defaults to 3784. `PORT` is honored as a
# fallback (PaaS convention). On Fly.io this is pinned to 8080 in fly.toml to
# match `internal_port`; see DEPLOYMENT.md.
AIM4_API_PORT=3784

# Serve the built client (dist/) from the Node server too ("1" or "true").
# Used by host mode (`npm run host`) so one process serves both
# the game and multiplayer on the same origin. NOT needed when the client is
# hosted separately (e.g. on Vercel).
AIM4_SERVE_STATIC=0
